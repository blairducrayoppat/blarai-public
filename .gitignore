# Environment secrets (local-only, never commit)
.env
.mcp.json

# TPM-sealed PA JWT public key (ADR-021) — per-chip artifact written by the
# provisioning ceremony (`python -m shared.security.provision_signing_key`).
# The TPM signing key is non-exportable and machine-bound, so its public half is
# NOT a portable constant and is never committed; each host regenerates it via
# the ceremony, and production JWT validation is fail-closed until it has run.
# The trust anchor is recorded as the ceremony's SHA-256 fingerprint in ADR-021,
# not as a committed key. (The old cleartext certs/pa_private.pem was removed in
# the same increment; it survives in git history only.)
certs/pa_public.pem
# Per-boot ephemeral mTLS certificate artifacts (ADR-026).
# These are regenerated fresh at every production boot; never committed.
# The CA private key is in-memory only; the nine PEM files below are
# the per-boot disk artifacts consumed by all host-side services.
certs/ca.pem
certs/pa_server.pem
certs/pa_server_key.pem
certs/gateway_client.pem
certs/gateway_client_key.pem
certs/orch_client.pem
certs/orch_client_key.pem
certs/router_client.pem
certs/router_client_key.pem
# Single-instance launcher lock (#670) — per-boot runtime artifact, co-located with certs/
certs/launcher.lock

# Vikunja bridge daemon data files (runtime artifacts)
tools/vikunja_mcp/bridge/state.json
tools/vikunja_mcp/bridge/processed.json
tools/vikunja_mcp/bridge/inbox.json
tools/vikunja_mcp/bridge/inbox.json.bad

# Escalation-watchdog dedup state (runtime; rebuilt on first run via
# silent-populate). Tracked-state in git would dirty the working tree
# every 5-min poll. See docs/governance/fleet-hygiene.md §1.
tools/fleet_observability/escalation_seen.json
tools/fleet_observability/escalation_seen.json.tmp

