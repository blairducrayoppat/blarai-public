.claude/file-history/
.claude/shell-snapshots/
.claude/session-env/
.claude/telemetry/
.claude/debug/
.claude/projects/

# Claude Projects freshness tracking — local-only dirty log populated by
# .git/hooks/post-commit. Cleared by the weekly dirty-check scheduled task
# after a Vikunja ticket is created.
docs/_claude_projects_dirty.log
tools/scheduled-tasks/logs/

# Wake launcher mutex (per fleet-hygiene §1 Drift Catalogue Pattern A;
# same drift class as the UAT2 entries that caused 60+ accumulated
# wake_launcher auto-stashes in 2026-04-22/23). Per w20.
.claude/scheduled_tasks.lock

