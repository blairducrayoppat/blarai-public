<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BlarAI.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:BlarAI.Desktop.ViewModels"
    xmlns:dtos="using:BlarAI.Desktop.Dtos"
    xmlns:controls="using:BlarAI.Desktop.Controls"
    mc:Ignorable="d"
    Title="BlarAI">

    <Grid x:Name="RootGrid"
          AutomationProperties.AutomationId="RootGrid"
          Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ── Custom title bar (Mica shows through) ─────────────────── -->
        <Border x:Name="AppTitleBar"
                AutomationProperties.AutomationId="AppTitleBar"
                Grid.Row="0" Padding="14,0,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                <TextBlock Text="BlarAI" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock x:Name="ChatTitleText"
                           AutomationProperties.AutomationId="ChatTitleText"
                           Opacity="0.6" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- ── Content: sidebar + chat ───────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Grid Grid.Column="0" Background="{ThemeResource SidebarBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="0">
                    <Button x:Name="NewChatButton" Click="OnNewChat"
                            AutomationProperties.AutomationId="NewChatButton"
                            AutomationProperties.Name="New chat"
                            Margin="12,12,12,4" HorizontalAlignment="Stretch" Height="40"
                            Background="{ThemeResource BlarAccentBrush}"
                            Foreground="{ThemeResource BlarAccentTextBrush}"
                            CornerRadius="20">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                            <TextBlock Text="New chat" />
                        </StackPanel>
                    </Button>
                    <!-- New project (#712): BlarAI creates the git repo and goes
                         straight into planning the build — the operator never
                         touches git. Secondary styling so New chat stays primary. -->
                    <Button x:Name="NewProjectButton" Click="OnNewProject"
                            AutomationProperties.AutomationId="NewProjectButton"
                            AutomationProperties.Name="New project"
                            Margin="12,0,12,8" HorizontalAlignment="Stretch" Height="40"
                            CornerRadius="20"
                            ToolTipService.ToolTip="Create a new coding project and start building">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8F4;" FontSize="14" />
                            <TextBlock Text="New project" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <ListView x:Name="SessionsList" Grid.Row="1"
                          AutomationProperties.AutomationId="SessionsList"
                          AutomationProperties.Name="Chat sessions"
                          ItemsSource="{x:Bind Sessions}"
                          SelectionChanged="OnSessionSelected"
                          Padding="6,0,6,0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="CornerRadius" Value="8" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="Padding" Value="10,8" />
                            <!-- Stretch the row to the full sidebar width so the
                                 per-session delete button (Grid.Column=1, Auto) sits
                                 hard-right by the scrollbar instead of hugging the
                                 title text (#668 follow-up). -->
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="dtos:ChatSession">
                            <!-- Per-session row: title + a trash button that is
                                 dim-visible by default and brightens on hover
                                 (PointerEntered), right-aligned to the scrollbar; plus a
                                 right-click context menu with Delete + Rename (#660/#668).
                                 The whole row carries the ContextFlyout so a right-click
                                 anywhere on the chat opens it. -->
                            <Grid PointerEntered="OnSessionRowPointerEntered"
                                  PointerExited="OnSessionRowPointerExited"
                                  Background="Transparent" Tag="{x:Bind Id}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Rename"
                                                        Click="OnRenameSessionMenu" Tag="{x:Bind Id}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE8AC;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="Delete"
                                                        Click="OnDeleteSessionMenu" Tag="{x:Bind Id}">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE74D;" />
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <TextBlock Grid.Column="0" Text="{x:Bind DisplayTitle}"
                                           TextTrimming="CharacterEllipsis" MaxLines="1"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1" Click="OnDeleteSessionButton" Tag="{x:Bind Id}"
                                        AutomationProperties.AutomationId="DeleteSessionButton"
                                        AutomationProperties.Name="Delete chat"
                                        Width="28" Height="28" Padding="0" Margin="6,0,0,0"
                                        Background="Transparent" BorderThickness="0" CornerRadius="6"
                                        Opacity="0.55" Tapped="OnDeleteSessionButtonTapped"
                                        ToolTipService.ToolTip="Delete this chat">
                                        <FontIcon Glyph="&#xE74D;" FontSize="13" Opacity="0.8" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerTransitions>
                        <TransitionCollection />
                    </ListView.ItemContainerTransitions>
                </ListView>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4"
                            Padding="10,8" HorizontalAlignment="Left">
                    <Button x:Name="GalleryButton" Click="OnOpenGallery" Width="40" Height="40"
                            AutomationProperties.AutomationId="GalleryButton"
                            AutomationProperties.Name="Generated images"
                            Background="Transparent" BorderThickness="0"
                            ToolTipService.ToolTip="Generated images">
                        <FontIcon Glyph="&#xEB9F;" FontSize="16" />
                    </Button>
                    <Button x:Name="ThemeButton" Click="OnToggleTheme" Width="40" Height="40"
                            AutomationProperties.AutomationId="ThemeButton"
                            AutomationProperties.Name="Toggle theme"
                            Background="Transparent" BorderThickness="0"
                            ToolTipService.ToolTip="Toggle light / dark">
                        <FontIcon x:Name="ThemeIcon" Glyph="&#xE706;" FontSize="16" />
                    </Button>
                    <Button x:Name="SettingsButton" Width="40" Height="40"
                            AutomationProperties.AutomationId="SettingsButton"
                            AutomationProperties.Name="Settings"
                            Background="Transparent" BorderThickness="0"
                            ToolTipService.ToolTip="Settings">
                        <FontIcon Glyph="&#xE713;" FontSize="16" />
                        <Button.Flyout>
                            <Flyout>
                                <StackPanel Width="290" Spacing="14">
                                    <TextBlock Text="Settings" FontWeight="SemiBold" FontSize="16" />

                                    <!-- Voice toggles (#660): each loads its model on
                                         demand when turned on and releases the RAM when
                                         turned off. Models are OFF at every launch (RAM-
                                         safe); a first toggle-on takes a few seconds. -->
                                    <StackPanel Spacing="2">
                                        <Grid>
                                            <ToggleSwitch x:Name="VoiceOutputToggle"
                                                          AutomationProperties.AutomationId="VoiceOutputToggle"
                                                          AutomationProperties.Name="Voice replies, BlarAI speaks"
                                                          Header="Voice replies (BlarAI speaks)"
                                                          OffContent="Off" OnContent="On"
                                                          Toggled="OnVoiceOutputToggled" />
                                            <ProgressRing x:Name="TtsLoadingRing"
                                                          AutomationProperties.AutomationId="TtsLoadingRing"
                                                          Width="18" Height="18"
                                                          HorizontalAlignment="Right" VerticalAlignment="Center"
                                                          IsActive="False" Visibility="Collapsed" />
                                        </Grid>
                                        <Grid>
                                            <ToggleSwitch x:Name="MicToggle"
                                                          AutomationProperties.AutomationId="MicToggle"
                                                          AutomationProperties.Name="Microphone, BlarAI listens"
                                                          Header="Microphone (BlarAI listens)"
                                                          OffContent="Off" OnContent="On"
                                                          Toggled="OnMicToggled" />
                                            <ProgressRing x:Name="SttLoadingRing"
                                                          AutomationProperties.AutomationId="SttLoadingRing"
                                                          Width="18" Height="18"
                                                          HorizontalAlignment="Right" VerticalAlignment="Center"
                                                          IsActive="False" Visibility="Collapsed" />
                                        </Grid>
                                        <TextBlock x:Name="VoiceUnavailableNote"
                                                   AutomationProperties.AutomationId="VoiceUnavailableNote"
                                                   Text="Voice models are not installed on this machine — text only."
                                                   FontSize="12" Opacity="0.6" TextWrapping="Wrap"
                                                   Visibility="Collapsed" />
                                        <TextBlock Text="Turning a voice feature on loads its model (a few seconds); off frees the memory."
                                                   FontSize="11" Opacity="0.5" TextWrapping="Wrap" Margin="0,2,0,0" />
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Voice" FontSize="12" Opacity="0.7" />
                                        <ComboBox x:Name="VoiceCombo"
                                                  AutomationProperties.AutomationId="VoiceCombo"
                                                  AutomationProperties.Name="Voice selection"
                                                  HorizontalAlignment="Stretch"
                                                  SelectionChanged="OnVoiceSelected" />
                                    </StackPanel>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Main chat column (also a drag-and-drop target) -->
            <Grid Grid.Column="1" AllowDrop="True"
                  DragOver="OnChatDragOver" Drop="OnChatDrop" Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Empty-state greeting -->
                <StackPanel x:Name="GreetingPanel" Grid.Row="0"
                            AutomationProperties.AutomationId="GreetingPanel"
                            AutomationProperties.Name="Greeting panel"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Spacing="8" Visibility="Collapsed">
                    <TextBlock Text="Hi Blair" FontSize="34" FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Drop a file or ask me anything." FontSize="16"
                               Opacity="0.6" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Transcript -->
                <ListView x:Name="MessagesList" Grid.Row="0"
                          AutomationProperties.AutomationId="MessagesList"
                          AutomationProperties.Name="Chat transcript"
                          ItemsSource="{x:Bind Messages}" SelectionMode="None"
                          Padding="0,12,0,12">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:MessageItem">
                            <Grid Margin="0,6" HorizontalAlignment="Stretch">
                                <Grid MaxWidth="760" HorizontalAlignment="Stretch" Margin="24,0">
                                    <!-- User: attachment chips + bubble (right-aligned) -->
                                    <StackPanel Visibility="{x:Bind UserVisibility}"
                                                HorizontalAlignment="Right" Spacing="6">
                                        <ItemsControl ItemsSource="{x:Bind Attachments}"
                                                      HorizontalAlignment="Right">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:AttachmentChip">
                                                    <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                            BorderThickness="1" CornerRadius="10"
                                                            Padding="8,5" Margin="6,0,0,0">
                                                        <StackPanel Orientation="Horizontal" Spacing="7">
                                                            <Image Source="{x:Bind Thumbnail}" Width="26" Height="26"
                                                                   Stretch="UniformToFill"
                                                                   Visibility="{x:Bind ThumbnailVisibility}" />
                                                            <FontIcon Glyph="{x:Bind Glyph}" FontSize="14"
                                                                      Visibility="{x:Bind IconVisibility}" />
                                                            <TextBlock Text="{x:Bind Filename}" VerticalAlignment="Center"
                                                                       MaxWidth="170" TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Border MaxWidth="540" HorizontalAlignment="Right"
                                                Background="{ThemeResource UserBubbleBrush}"
                                                CornerRadius="16" Padding="14,10"
                                                Visibility="{x:Bind TextVisibility, Mode=OneWay}">
                                            <TextBlock Text="{x:Bind Text, Mode=OneWay}"
                                                       Foreground="{ThemeResource UserBubbleTextBrush}"
                                                       TextWrapping="Wrap" IsTextSelectionEnabled="True" />
                                        </Border>
                                    </StackPanel>
                                    <!-- Assistant block -->
                                    <StackPanel Visibility="{x:Bind AssistantVisibility}"
                                                HorizontalAlignment="Stretch" Spacing="6">
                                        <TextBlock Text="BlarAI" FontSize="12" Opacity="0.55" />
                                        <controls:MarkdownBlock Markdown="{x:Bind Text, Mode=OneWay}"
                                                                Visibility="{x:Bind MarkdownVisibility, Mode=OneWay}" />
                                        <!-- Ingest editable preview: edit-before-approve (#663 Workstream A).
                                             The Edit toggle swaps the render for an editable markdown-source
                                             box; Approve and Reject both go through the structured
                                             ingest_decide channel (Approve carries the possibly-edited body). -->
                                        <TextBox Text="{x:Bind EditableBody, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Visibility="{x:Bind EditBoxVisibility, Mode=OneWay}"
                                                 AutomationProperties.AutomationId="IngestEditBox"
                                                 AutomationProperties.Name="Edit the article before approving"
                                                 AcceptsReturn="True" TextWrapping="Wrap"
                                                 MaxHeight="340" IsSpellCheckEnabled="False"
                                                 FontFamily="Consolas"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 Background="{ThemeResource ComposerBrush}"
                                                 BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                 BorderThickness="1" CornerRadius="8" Padding="10" />
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0"
                                                    Visibility="{x:Bind IngestActionsVisibility, Mode=OneWay}">
                                            <Button Click="OnIngestEditToggle" Tag="{x:Bind}"
                                                    AutomationProperties.AutomationId="IngestEditButton"
                                                    Content="{x:Bind EditButtonText, Mode=OneWay}"
                                                    ToolTipService.ToolTip="Trim noise/ads before approving" />
                                            <Button Click="OnIngestApprove" Tag="{x:Bind}"
                                                    AutomationProperties.AutomationId="IngestApproveButton"
                                                    Content="Approve"
                                                    Background="{ThemeResource BlarAccentBrush}"
                                                    Foreground="{ThemeResource BlarAccentTextBrush}"
                                                    ToolTipService.ToolTip="Store the (curated) document in the knowledge bank" />
                                            <Button Click="OnIngestReject" Tag="{x:Bind}"
                                                    AutomationProperties.AutomationId="IngestRejectButton"
                                                    Content="Reject"
                                                    ToolTipService.ToolTip="Discard this document" />
                                        </StackPanel>
                                        <!-- Image follow-up actions (#712): Edit / Save under a
                                             generated image. Edit pre-fills the composer with
                                             /edit <ref>; Save exports the full-res PNG (ADR-033 §D). -->
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0"
                                                    Visibility="{x:Bind ImageActionsVisibility, Mode=OneWay}">
                                            <Button Click="OnImageEdit" Tag="{x:Bind}"
                                                    AutomationProperties.AutomationId="ImageEditButton"
                                                    Content="Edit"
                                                    ToolTipService.ToolTip="Change this image with a prompt (/edit)" />
                                            <Button Click="OnImageSave" Tag="{x:Bind}"
                                                    AutomationProperties.AutomationId="ImageSaveButton"
                                                    Content="Save"
                                                    ToolTipService.ToolTip="Save this image to a file" />
                                        </StackPanel>
                                        <!-- Dispatch plan actions (#712): Approve / Reject under a
                                             build plan, so the New-project flow finishes by clicking. -->
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0"
                                                    Visibility="{x:Bind DispatchPlanActionsVisibility, Mode=OneWay}">
                                            <Button Click="OnDispatchApprove" Tag="{x:Bind}"
                                                    AutomationProperties.AutomationId="DispatchApproveButton"
                                                    Content="Approve &amp; build"
                                                    Background="{ThemeResource BlarAccentBrush}"
                                                    Foreground="{ThemeResource BlarAccentTextBrush}"
                                                    ToolTipService.ToolTip="Start building (/dispatch approve)" />
                                            <Button Click="OnDispatchReject" Tag="{x:Bind}"
                                                    AutomationProperties.AutomationId="DispatchRejectButton"
                                                    Content="Reject"
                                                    ToolTipService.ToolTip="Discard this plan (/dispatch reject)" />
                                        </StackPanel>
                                        <!-- Per-message play button: speak this reply on demand (ADR-017) -->
                                        <Button Click="OnPlayMessage" Tag="{x:Bind}"
                                                Visibility="{x:Bind PlayVisibility, Mode=OneWay}"
                                                Width="30" Height="30" Padding="0" Margin="0,2,0,0"
                                                HorizontalAlignment="Left"
                                                Background="Transparent" BorderThickness="0" CornerRadius="15"
                                                ToolTipService.ToolTip="Play this reply">
                                            <FontIcon Glyph="&#xE768;" FontSize="13" Opacity="0.7" />
                                        </Button>
                                        <!-- PGOV denial parity card -->
                                        <Border Visibility="{x:Bind DeniedVisibility, Mode=OneWay}"
                                                AutomationProperties.AutomationId="PgovDenialCard"
                                                AutomationProperties.Name="PGOV denial card"
                                                Background="{ThemeResource DeniedFillBrush}"
                                                BorderBrush="{ThemeResource DeniedBorderBrush}"
                                                BorderThickness="1" CornerRadius="10"
                                                Padding="12,10" Margin="0,4,0,0">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="⚠ Response held by the output validator"
                                                           AutomationProperties.AutomationId="PgovDenialHeading"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="{x:Bind ReasonText, Mode=OneWay}"
                                                           AutomationProperties.AutomationId="PgovReasonText"
                                                           Opacity="0.8" TextWrapping="Wrap"
                                                           Visibility="{x:Bind ReasonVisibility, Mode=OneWay}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Composer area -->
                <Grid Grid.Row="1" Padding="24,8,24,18">
                    <StackPanel HorizontalAlignment="Center" MaxWidth="1100" Spacing="6">

                        <!-- Slash-command soft autocomplete -->
                        <Border x:Name="SuggestBox" Visibility="Collapsed"
                                AutomationProperties.AutomationId="SuggestBox"
                                AutomationProperties.Name="Command suggestions"
                                Background="{ThemeResource ComposerBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="12">
                            <ListView x:Name="SuggestList" SelectionMode="None"
                                      AutomationProperties.AutomationId="SuggestList"
                                      AutomationProperties.Name="Command suggestion list"
                                      IsItemClickEnabled="True" ItemClick="OnSuggestionClick"
                                      MaxHeight="200" />
                        </Border>

                        <!-- Composer pill (drag-and-drop target) -->
                        <Border AllowDrop="True" DragOver="OnChatDragOver" Drop="OnChatDrop"
                                Background="{ThemeResource ComposerBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="24" Padding="6">
                            <StackPanel Spacing="6">

                                <!-- Pending attachment chips -->
                                <ItemsControl ItemsSource="{x:Bind PendingAttachments}"
                                              Margin="6,2,6,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AttachmentChip">
                                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1" CornerRadius="10"
                                                    Padding="8,5" Margin="0,0,6,0">
                                                <StackPanel Orientation="Horizontal" Spacing="7">
                                                    <Image Source="{x:Bind Thumbnail}" Width="26" Height="26"
                                                           Stretch="UniformToFill"
                                                           Visibility="{x:Bind ThumbnailVisibility}" />
                                                    <FontIcon Glyph="{x:Bind Glyph}" FontSize="14"
                                                              Visibility="{x:Bind IconVisibility}" />
                                                    <TextBlock Text="{x:Bind Filename}" VerticalAlignment="Center"
                                                               MaxWidth="160" TextTrimming="CharacterEllipsis" />
                                                    <Button Click="OnRemovePending" Tag="{x:Bind Filename}"
                                                            Width="22" Height="22" Padding="0"
                                                            Background="Transparent" BorderThickness="0"
                                                            ToolTipService.ToolTip="Remove">
                                                        <FontIcon Glyph="&#xE711;" FontSize="11" />
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Buttons + input + send -->
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Bottom">
                                        <Button x:Name="AttachButton" Click="OnAttach" Width="40" Height="40"
                                                AutomationProperties.AutomationId="AttachButton"
                                                AutomationProperties.Name="Attach file"
                                                Background="Transparent" BorderThickness="0" CornerRadius="20"
                                                ToolTipService.ToolTip="Attach a file">
                                            <FontIcon Glyph="&#xE723;" FontSize="16" />
                                        </Button>
                                        <Button x:Name="ScreenshotButton" Click="OnScreenshot" Width="40" Height="40"
                                                AutomationProperties.AutomationId="ScreenshotButton"
                                                AutomationProperties.Name="Capture screenshot"
                                                Background="Transparent" BorderThickness="0" CornerRadius="20"
                                                ToolTipService.ToolTip="Capture a screenshot">
                                            <FontIcon Glyph="&#xE722;" FontSize="16" />
                                        </Button>
                                        <Button x:Name="MicButton" Click="OnMicButton" Width="40" Height="40"
                                                AutomationProperties.AutomationId="MicButton"
                                                AutomationProperties.Name="Microphone"
                                                Background="Transparent" BorderThickness="0" CornerRadius="20"
                                                IsEnabled="False"
                                                ToolTipService.ToolTip="Tap to talk; tap again to stop">
                                            <FontIcon x:Name="MicIcon" Glyph="&#xE720;" FontSize="16" />
                                        </Button>
                                        <Button x:Name="RecordButton" Width="40" Height="40"
                                                AutomationProperties.AutomationId="RecordButton"
                                                AutomationProperties.Name="Screen recording"
                                                Background="Transparent" BorderThickness="0" CornerRadius="20"
                                                IsEnabled="False"
                                                ToolTipService.ToolTip="Screen recording (coming soon)">
                                            <FontIcon Glyph="&#xE7C8;" FontSize="16" />
                                        </Button>
                                    </StackPanel>

                                    <TextBox x:Name="PromptBox" Grid.Column="1"
                                             AutomationProperties.AutomationId="PromptBox"
                                             AutomationProperties.Name="Message input"
                                             PlaceholderText="Message BlarAI…"
                                             BorderThickness="0" Background="Transparent"
                                             TextWrapping="Wrap" AcceptsReturn="True"
                                             MinHeight="24" MaxHeight="340"
                                             VerticalAlignment="Bottom"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             TextChanged="OnPromptTextChanged"
                                             PreviewKeyDown="OnPromptKeyDown" />

                                    <Button x:Name="SendButton" Grid.Column="2" Click="OnSend"
                                            AutomationProperties.AutomationId="SendButton"
                                            AutomationProperties.Name="Send"
                                            Width="40" Height="40" CornerRadius="20"
                                            VerticalAlignment="Bottom"
                                            Background="{ThemeResource BlarAccentBrush}"
                                            Foreground="{ThemeResource BlarAccentTextBrush}"
                                            ToolTipService.ToolTip="Send">
                                        <FontIcon Glyph="&#xE724;" FontSize="16"
                                                  Foreground="{ThemeResource BlarAccentTextBrush}" />
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Connection / status strip -->
                <InfoBar x:Name="StatusBar" Grid.Row="0" VerticalAlignment="Top"
                         AutomationProperties.AutomationId="StatusBar"
                         AutomationProperties.Name="Status bar"
                         IsOpen="False" IsClosable="True" Margin="24,8" />

                <!-- ── Generated-image gallery (UC-010 Phase 2, #668) ───────────
                     An OVERLAY pane layered over the chat column (RowSpan covers
                     transcript + composer). The chat stays intact underneath; the
                     X (OnCloseGallery) returns to it. Opaque themed background so
                     the chat does not bleed through. Collapsed until OnOpenGallery.
                     Tiles are DISPLAY-ONLY: each Image is hit-test-off with an
                     in-memory BitmapImage source only — no nav/tap handlers (the
                     same posture as the inline markdown render). -->
                <Grid x:Name="GalleryOverlay" Grid.Row="0" Grid.RowSpan="2"
                      AutomationProperties.AutomationId="GalleryOverlay"
                      AutomationProperties.Name="Generated image gallery"
                      Visibility="Collapsed"
                      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header: title + close -->
                    <Grid Grid.Row="0" Padding="24,14,24,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Generated images"
                                   FontSize="20" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1" Click="OnCloseGallery"
                                AutomationProperties.AutomationId="GalleryCloseButton"
                                AutomationProperties.Name="Close gallery"
                                Width="40" Height="40"
                                Background="Transparent" BorderThickness="0" CornerRadius="20"
                                ToolTipService.ToolTip="Close">
                            <FontIcon Glyph="&#xE711;" FontSize="16" />
                        </Button>
                    </Grid>

                    <!-- Empty state -->
                    <TextBlock x:Name="GalleryEmptyState" Grid.Row="1"
                               AutomationProperties.AutomationId="GalleryEmptyState"
                               Text="No generated images yet"
                               FontSize="15" Opacity="0.6"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="Collapsed" />

                    <!-- Thumbnail grid -->
                    <GridView x:Name="GalleryGrid" Grid.Row="1"
                              AutomationProperties.AutomationId="GalleryGrid"
                              AutomationProperties.Name="Generated images grid"
                              ItemsSource="{x:Bind GalleryImages}"
                              SelectionMode="None" IsItemClickEnabled="False"
                              Padding="18,4,18,18">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="vm:GalleryImageItem">
                                <!-- 150x150 display-only tile -->
                                <Border Width="150" Height="150" Margin="6"
                                        CornerRadius="10"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <!-- Decoded thumbnail (in-memory BitmapImage ONLY,
                                             hit-test off — DISPLAY-ONLY, no nav/tap). -->
                                        <Image Source="{x:Bind Thumbnail, Mode=OneWay}"
                                               Stretch="UniformToFill"
                                               IsHitTestVisible="False"
                                               Visibility="{x:Bind ThumbnailVisibility, Mode=OneWay}" />
                                        <!-- Placeholder while the thumbnail resolves
                                             (or stays, if no bytes are available). -->
                                        <FontIcon Glyph="&#xEB9F;" FontSize="28" Opacity="0.4"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Visibility="{x:Bind PlaceholderVisibility, Mode=OneWay}" />

                                        <!-- Saved ✓ badge (top-left) -->
                                        <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                                Margin="6" CornerRadius="10" Padding="4,2"
                                                Background="#CC2E7D32"
                                                Visibility="{x:Bind SavedBadgeVisibility, Mode=OneWay}"
                                                ToolTipService.ToolTip="Saved to disk">
                                            <FontIcon Glyph="&#xE73E;" FontSize="11" Foreground="White" />
                                        </Border>
                                        <!-- Encrypted-only 🔒 badge (top-left) -->
                                        <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                                Margin="6" CornerRadius="10" Padding="4,2"
                                                Background="#99000000"
                                                Visibility="{x:Bind LockBadgeVisibility, Mode=OneWay}"
                                                ToolTipService.ToolTip="Encrypted only (not saved to disk)">
                                            <FontIcon Glyph="&#xE72E;" FontSize="11" Foreground="White" />
                                        </Border>

                                        <!-- Size · date caption (bottom strip) -->
                                        <Border VerticalAlignment="Bottom" Background="#99000000"
                                                Padding="6,3">
                                            <TextBlock Text="{x:Bind SizeAndDate}"
                                                       FontSize="10" Foreground="White"
                                                       TextTrimming="CharacterEllipsis" MaxLines="1" />
                                        </Border>

                                        <!-- Always-visible corner actions (top-right). Made
                                             always-visible deliberately — the hover-only
                                             session button was the discoverability bug WS4
                                             fixes; the gallery should not repeat it. -->
                                        <StackPanel Orientation="Horizontal" Spacing="2"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Margin="4">
                                            <Button Click="OnGallerySaveImage" Tag="{x:Bind ImageId}"
                                                    AutomationProperties.AutomationId="GallerySaveButton"
                                                    AutomationProperties.Name="Save image to disk"
                                                    IsEnabled="{x:Bind SaveEnabled, Mode=OneWay}"
                                                    Width="28" Height="28" Padding="0"
                                                    Background="#CC1F1F1F" BorderThickness="0" CornerRadius="6"
                                                    ToolTipService.ToolTip="Save to disk">
                                                <FontIcon Glyph="&#xE74E;" FontSize="12" Foreground="White" />
                                            </Button>
                                            <Button Click="OnGalleryDeleteImage" Tag="{x:Bind ImageId}"
                                                    AutomationProperties.AutomationId="GalleryDeleteButton"
                                                    AutomationProperties.Name="Delete image"
                                                    Width="28" Height="28" Padding="0"
                                                    Background="#CC1F1F1F" BorderThickness="0" CornerRadius="6"
                                                    ToolTipService.ToolTip="Delete">
                                                <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="White" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
