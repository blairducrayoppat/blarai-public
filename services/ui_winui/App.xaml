<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="BlarAI.Desktop.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:BlarAI.Desktop.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Shared converters -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:StringToVisibilityConverter x:Key="StringToVis" />

            <!-- ── BlAIr warm palette ──────────────────────────────────────────
                 The app is recoloured to the "BlAIr" brand: amber/copper on a
                 warm dark espresso ground, matching the gold app icon. No blue.
                 Hero accent = amber #F5A623; hover/pressed = copper #C9772E;
                 text/icon ON amber = espresso #201509; light text on dark
                 surfaces = warm cream #ECDBBD; ground = near-black espresso.

                 We override SystemAccentColor (+ its dark/light shade variants)
                 so every *system*-driven accent surface picks up the warm hue:
                 ListView selection highlight, focus visuals, ToggleSwitch
                 on-state, ComboBox selection, TextBox text-selection, and
                 RichTextBlock hyperlinks. Without this the app inherited the
                 Windows user accent (commonly blue) on all of those. -->
            <Color x:Key="SystemAccentColor">#F5A623</Color>
            <!-- Light-theme shade ramp (Light1..3 = progressively lighter). -->
            <Color x:Key="SystemAccentColorLight1">#F8B84A</Color>
            <Color x:Key="SystemAccentColorLight2">#FAC971</Color>
            <Color x:Key="SystemAccentColorLight3">#FCDBA0</Color>
            <!-- Dark-theme shade ramp (Dark1..3 = progressively darker = copper). -->
            <Color x:Key="SystemAccentColorDark1">#D98A2B</Color>
            <Color x:Key="SystemAccentColorDark2">#C9772E</Color>
            <Color x:Key="SystemAccentColorDark3">#A85F22</Color>

            <!-- BlarAI accent — the BlAIr amber hero accent.
                 Light/dark variants keep contrast comfortable in both themes. -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <!-- Amber hero accent; espresso text sits on it for contrast. -->
                    <SolidColorBrush x:Key="BlarAccentBrush" Color="#F5A623" />
                    <SolidColorBrush x:Key="BlarAccentTextBrush" Color="#201509" />
                    <!-- User bubble: warm amber tint, espresso text. -->
                    <SolidColorBrush x:Key="UserBubbleBrush" Color="#FDF0DA" />
                    <SolidColorBrush x:Key="UserBubbleTextBrush" Color="#201509" />
                    <SolidColorBrush x:Key="SidebarBrush" Color="#FBF6EE" />
                    <SolidColorBrush x:Key="ComposerBrush" Color="#FFFDFA" />
                    <SolidColorBrush x:Key="DeniedBorderBrush" Color="#C9772E" />
                    <SolidColorBrush x:Key="DeniedFillBrush" Color="#FBEFDD" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <!-- Amber hero accent; espresso text sits on it for contrast. -->
                    <SolidColorBrush x:Key="BlarAccentBrush" Color="#F5A623" />
                    <SolidColorBrush x:Key="BlarAccentTextBrush" Color="#201509" />
                    <!-- User bubble: deep copper-espresso fill, warm cream text. -->
                    <SolidColorBrush x:Key="UserBubbleBrush" Color="#3A2A14" />
                    <SolidColorBrush x:Key="UserBubbleTextBrush" Color="#ECDBBD" />
                    <SolidColorBrush x:Key="SidebarBrush" Color="#1A130B" />
                    <SolidColorBrush x:Key="ComposerBrush" Color="#241B10" />
                    <SolidColorBrush x:Key="DeniedBorderBrush" Color="#C9772E" />
                    <SolidColorBrush x:Key="DeniedFillBrush" Color="#3A2F1C" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
