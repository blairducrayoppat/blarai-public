<test_plan>
  <total_tests>8 configurations (Groups A through D)</total_tests>
  <execution_policy>
    - WARMUP_RUNS = 2, MEASURED_RUNS = 5, MAX_NEW_TOKENS = 128 (same as P5-005a)
    - temperature=0.0, do_sample=False, top_k=1, top_p=1.0 (deterministic)
    - Each band wrapped in try/except for OOM-safe iteration
    - On OOM or allocation failure at a band: record the error fingerprint, RSS at failure,
      and the band value, then CONTINUE to next test (do not abort the entire run)
    - pipeline gc.collect() + sleep(2) between test configs (same as P5-005a)
    - AC power enforcement at script start (fail-closed)
    - Evidence written atomically after each test completes (incremental save)
  </execution_policy>

  <group id="A" name="Extended Context Baseline" count="2">
    <purpose>Map the unknown territory beyond 4,096 tokens. Characterize TPS degradation curve, TTFT scaling, and RSS growth at extended context lengths.</purpose>
    <note>Bands 128-4096 are already measured in P5-005a. Only run new bands here. Include band 4096 as overlap anchor for cross-study calibration.</note>

    <test id="A-01" name="14B Baseline Extended">
      <model>models/qwen3-14b/openvino-int4-gpu</model>
      <draft_model>None</draft_model>
      <runtime_properties>{}</runtime_properties>
      <pipeline_kwargs>{}</pipeline_kwargs>
      <num_assistant_tokens>N/A (not speculative)</num_assistant_tokens>
      <bands>[4096, 6144, 8192, 12288, 16384, 20480]</bands>
      <purpose>Baseline degradation curve + memory growth confirmation without speculative decoding</purpose>
    </test>

    <test id="A-02" name="14B + 0.6B Draft Extended">
      <model>models/qwen3-14b/openvino-int4-gpu</model>
      <draft_model>models/qwen3-0.6b/openvino-int4-gpu</draft_model>
      <draft_device>GPU</draft_device>
      <runtime_properties>{}</runtime_properties>
      <pipeline_kwargs>{}</pipeline_kwargs>
      <num_assistant_tokens>5</num_assistant_tokens>
      <assistant_confidence_threshold>0.0</assistant_confidence_threshold>
      <bands>[4096, 6144, 8192, 12288, 16384, 20480]</bands>
      <purpose>T-09 equivalent at extended context — the primary measurement for context expansion feasibility</purpose>
    </test>
  </group>

  <group id="B" name="Missing Optimization Combinations" count="2">
    <purpose>Fill critical gaps from P5-005a: XAttention was never tested without INT8 KV, and speculative decoding was never combined with XAttention.</purpose>

    <test id="B-01" name="14B + XAttention Only">
      <model>models/qwen3-14b/openvino-int4-gpu</model>
      <draft_model>None</draft_model>
      <runtime_properties>{"GPU_ENABLE_SDPA_OPTIMIZATION": true}</runtime_properties>
      <pipeline_kwargs>{}</pipeline_kwargs>
      <num_assistant_tokens>N/A (not speculative)</num_assistant_tokens>
      <bands>[512, 2048, 4096, 8192]</bands>
      <purpose>Isolate XAttention benefit without INT8 KV contamination. Compare to T-01 baseline.</purpose>
    </test>

    <test id="B-02" name="14B + 0.6B Draft + XAttention">
      <model>models/qwen3-14b/openvino-int4-gpu</model>
      <draft_model>models/qwen3-0.6b/openvino-int4-gpu</draft_model>
      <draft_device>GPU</draft_device>
      <runtime_properties>{"GPU_ENABLE_SDPA_OPTIMIZATION": true}</runtime_properties>
      <pipeline_kwargs>{}</pipeline_kwargs>
      <num_assistant_tokens>5</num_assistant_tokens>
      <assistant_confidence_threshold>0.0</assistant_confidence_threshold>
      <bands>[512, 2048, 4096, 8192]</bands>
      <purpose>The untested combination of the two best independent boosters. If this outperforms A-02, it becomes the new best config and gets extended in Group D.</purpose>
    </test>
  </group>

  <group id="C" name="Speculation Depth Tuning" count="3">
    <purpose>P5-005a only tested num_assistant_tokens=5. At longer contexts, the draft acceptance rate may shift. Sweep 3, 7, 10 to find the optimal depth.</purpose>

    <test id="C-01" name="14B + 0.6B Draft (NAT=3)">
      <model>models/qwen3-14b/openvino-int4-gpu</model>
      <draft_model>models/qwen3-0.6b/openvino-int4-gpu</draft_model>
      <draft_device>GPU</draft_device>
      <runtime_properties>{}</runtime_properties>
      <pipeline_kwargs>{}</pipeline_kwargs>
      <num_assistant_tokens>3</num_assistant_tokens>
      <assistant_confidence_threshold>0.0</assistant_confidence_threshold>
      <bands>[512, 4096, 8192]</bands>
      <purpose>Check if less speculation is faster at long context</purpose>
    </test>

    <test id="C-02" name="14B + 0.6B Draft (NAT=7)">
      <model>models/qwen3-14b/openvino-int4-gpu</model>
      <draft_model>models/qwen3-0.6b/openvino-int4-gpu</draft_model>
      <draft_device>GPU</draft_device>
      <runtime_properties>{}</runtime_properties>
      <pipeline_kwargs>{}</pipeline_kwargs>
      <num_assistant_tokens>7</num_assistant_tokens>
      <assistant_confidence_threshold>0.0</assistant_confidence_threshold>
      <bands>[512, 4096, 8192]</bands>
      <purpose>Check if more speculation helps at long context</purpose>
    </test>

    <test id="C-03" name="14B + 0.6B Draft (NAT=10)">
      <model>models/qwen3-14b/openvino-int4-gpu</model>
      <draft_model>models/qwen3-0.6b/openvino-int4-gpu</draft_model>
      <draft_device>GPU</draft_device>
      <runtime_properties>{}</runtime_properties>
      <pipeline_kwargs>{}</pipeline_kwargs>
      <num_assistant_tokens>10</num_assistant_tokens>
      <assistant_confidence_threshold>0.0</assistant_confidence_threshold>
      <bands>[512, 4096, 8192]</bands>
      <purpose>Check aggressive speculation at long context</purpose>
    </test>
  </group>

  <group id="D" name="Best Config Extended Run" count="1" conditional="true">
    <purpose>After Groups A-C complete and data is analyzed in-script, take the winning configuration and run it at the full extended range to characterize the best config across maximum context.</purpose>
    <selection_logic>
      1. From Groups B+C, identify the config with highest mean TPS at band 4096.
      2. If B-02 at band 4096 > A-02 at band 4096, the best config uses XAttention.
      3. From Group C, identify the best num_assistant_tokens value at band 4096.
      4. Combine: best_runtime_properties + best_num_assistant_tokens.
      5. If no improvement over A-02 at band 4096, use A-02's config for D-01 (NAT=5, no XAttention).
    </selection_logic>

    <test id="D-01" name="Best Config Extended">
      <model>models/qwen3-14b/openvino-int4-gpu</model>
      <draft_model>models/qwen3-0.6b/openvino-int4-gpu</draft_model>
      <draft_device>GPU</draft_device>
      <runtime_properties>DETERMINED AT RUNTIME from selection_logic</runtime_properties>
      <num_assistant_tokens>DETERMINED AT RUNTIME from selection_logic</num_assistant_tokens>
      <assistant_confidence_threshold>0.0</assistant_confidence_threshold>
      <bands>[4096, 8192, 12288, 16384, 20480]</bands>
      <purpose>Characterize the winning configuration at maximum extended context. This is the primary data artifact for the Lead Architect's cap decision.</purpose>
    </test>
  </group>
</test_plan>

